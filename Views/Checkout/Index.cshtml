@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<section class="page-band">
    <div class="container">
        <h1>Checkout</h1>
        <p>Confirm your delivery details and place the order.</p>
    </div>
</section>

<section class="container py-4">
    <div class="row g-4">
        <div class="col-lg-7">
            <form asp-action="PlaceOrder" method="post" class="form-card">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control mb-3" />
                <label asp-for="DeliveryAddress" class="form-label"></label>
                <input asp-for="DeliveryAddress" class="form-control mb-3" />
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control mb-3" />
                <button class="btn btn-brand btn-lg">Place Order</button>
            </form>
        </div>
        <div class="col-lg-5">
            <div class="summary-card">
                <h4>Order Summary</h4>
                @foreach (var item in Model.CartItems)
                {
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>@item.FoodItem?.Name x @item.Quantity</span>
                        <strong>$@item.LineTotal</strong>
                    </div>
                }
                <div class="d-flex justify-content-between pt-3 fs-5">
                    <span>Total</span>
                    <strong>$@Model.Total</strong>
                </div>
            </div>
        </div>
    </div>
</section>
