@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<section class="auth-wrap">
    <form asp-action="Register" method="post" class="auth-card">
        <h2>Create account</h2>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="FullName" class="form-control" placeholder="Full name" />
        <input asp-for="Email" class="form-control" placeholder="Email" />
        <input asp-for="Address" class="form-control" placeholder="Delivery address" />
        <input asp-for="Password" class="form-control" placeholder="Password" />
        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
        <button class="btn btn-brand w-100">Register</button>
        <a asp-action="Login">Already have an account?</a>
    </form>
</section>
