@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<section class="auth-wrap">
    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-card">
        <h2>Welcome back</h2>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="Email" class="form-control" placeholder="Email" />
        <input asp-for="Password" class="form-control" placeholder="Password" />
        <label class="form-check"><input asp-for="RememberMe" class="form-check-input" /> Remember me</label>
        <button class="btn btn-brand w-100">Login</button>
        <a asp-action="Register">Create a new account</a>
    </form>
</section>
