@model IEnumerable<FoodItem>

@if (!Model.Any())
{
    <div class="col-12">
        <div class="empty-state">No dishes found. Try a different search or category.</div>
    </div>
}
else
{
    foreach (var item in Model)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="food-card h-100">
                <a asp-controller="Menu" asp-action="Details" asp-route-id="@item.Id">
                    <img src="@item.ImageUrl" class="food-card-img" alt="@item.Name" />
                </a>
                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <div>
                            <h5 class="mb-1">@item.Name</h5>
                            <span class="badge text-bg-light">@item.Category?.Name</span>
                        </div>
                        <strong class="price">$@item.Price</strong>
                    </div>
                    <p class="text-muted small mt-2 mb-3">@item.Description</p>
                    <button class="btn btn-brand w-100 add-to-cart" data-food-id="@item.Id">
                        <i class="bi bi-plus-circle"></i> Add to cart
                    </button>
                </div>
            </div>
        </div>
    }
}
