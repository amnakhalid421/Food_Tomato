@model FoodItem
@{
    ViewData["Title"] = Model.Name;
}

<section class="container py-5">
    <div class="row g-5 align-items-center">
        <div class="col-lg-6">
            <img class="detail-img" src="@Model.ImageUrl" alt="@Model.Name" />
        </div>
        <div class="col-lg-6">
            <span class="badge text-bg-light mb-3">@Model.Category?.Name</span>
            <h1>@Model.Name</h1>
            <p class="lead text-muted">@Model.Description</p>
            <h3 class="price mb-4">$@Model.Price</h3>
            <button class="btn btn-brand btn-lg add-to-cart" data-food-id="@Model.Id">Add to cart</button>
            <a class="btn btn-outline-dark btn-lg" asp-action="Index">Back to menu</a>
        </div>
    </div>
</section>
