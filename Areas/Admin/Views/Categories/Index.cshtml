@model IEnumerable<Category>
@{
    ViewData["Title"] = "Manage Categories";
}
<section class="container py-4">
    <div class="admin-nav"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a><a asp-controller="FoodItems" asp-action="Index">Food Items</a><a asp-controller="Categories" asp-action="Index">Categories</a><a asp-controller="Orders" asp-action="Index">Orders</a><a asp-controller="Users" asp-action="Index">Users</a></div>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Categories</h1>
        <a class="btn btn-brand" asp-action="Create">Add Category</a>
    </div>
    <div class="row g-3">
        @foreach (var category in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="category-admin">
                    <img src="@category.ImageUrl" alt="" />
                    <div><h5>@category.Name</h5><span>@(category.IsActive ? "Active" : "Hidden")</span></div>
                    <div class="ms-auto">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@category.Id">Edit</a>
                        <form asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline"><button class="btn btn-sm btn-outline-danger">Delete</button></form>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
