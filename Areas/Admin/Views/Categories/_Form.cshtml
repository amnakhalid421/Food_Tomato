@model Category
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<label asp-for="Name" class="form-label"></label>
<input asp-for="Name" class="form-control mb-3" />
<label asp-for="ImageUrl" class="form-label"></label>
<input asp-for="ImageUrl" class="form-control mb-3" />
<label class="form-check mb-3"><input asp-for="IsActive" class="form-check-input" /> Active</label>
<button class="btn btn-brand">Save</button>
<a class="btn btn-outline-dark" asp-action="Index">Cancel</a>
